BLOCKSCOUT_BACKEND_REPO=blockscout
BLOCKSCOUT_BACKEND_TAG=latest
BLOCKSCOUT_FRONTEND_TAG=latest
CHAIN_TYPE=default
# Blockscout backend and the user-ops indexer use the local debug-enabled
# zksys EN. host.docker.internal is mapped to Docker's host gateway via
# extra_hosts in the compose file, so it tracks the actual bridge IP even on
# daemons with a custom bip (deploy-zksys-en-rpc.sh auto-detects the same
# address for the EN bind). The public frontend still advertises
# NEXT_PUBLIC_NETWORK_RPC_URL below, which points at the non-debug public EN
# behind nginx.
L2_RPC_URL=http://host.docker.internal:3051
SETTLEMENT_RPC_URL=https://rpc-gw.tanenbaum.io/
CHAIN_ID=57057
FIRST_BLOCK=3
TRACE_FIRST_BLOCK=3
COIN_NAME=TSYS
COIN_SYMBOL=TSYS
NETWORK_NAME=zkTanenbaum
NETWORK_SHORT_NAME=zkTanenbaum
PUBLIC_PROTOCOL=https
PUBLIC_WS_PROTOCOL=wss
PUBLIC_HOST=explorer-zk.tanenbaum.io
PUBLIC_PORT=443
HOST_BIND_IP=127.0.0.1
HOST_PORT=5200
ROLLUP_L1_BASE_URL=https://explorer-gw.tanenbaum.io
NEXT_PUBLIC_HOMEPAGE_CHARTS=['daily_txs']
NEXT_PUBLIC_HOMEPAGE_HERO_BANNER_CONFIG={'background':['#205efe'],'text_color':['#ffffff']}
NETWORK_LOGO=https://explorer-zk.tanenbaum.io/branding-assets/zktanenbaum-logo.svg
NETWORK_LOGO_DARK=https://explorer-zk.tanenbaum.io/branding-assets/zktanenbaum-logo.svg
NEXT_PUBLIC_NETWORK_ICON=https://explorer-zk.tanenbaum.io/branding-assets/zktanenbaum-icon.svg
NEXT_PUBLIC_NETWORK_ICON_DARK=https://explorer-zk.tanenbaum.io/branding-assets/zktanenbaum-icon.svg
FAVICON_MASTER_URL=https://explorer-zk.tanenbaum.io/branding-assets/zktanenbaum-icon.svg
NETWORK_LOGO_FILE=zktanenbaum-logo.svg
NETWORK_LOGO_DARK_FILE=zktanenbaum-logo.svg
NETWORK_ICON_FILE=zktanenbaum-icon.svg
NETWORK_ICON_DARK_FILE=zktanenbaum-icon.svg
NEXT_PUBLIC_NETWORK_RPC_URL=https://rpc-zk.tanenbaum.io/
NEXT_PUBLIC_USE_NEXT_JS_PROXY=false
NEXT_PUBLIC_API_DOCS_TABS=['rest_api','eth_rpc_api','graphql_api']
NEXT_PUBLIC_WEB3_WALLETS=['metamask']
NEXT_PUBLIC_AD_BANNER_PROVIDER=none
NEXT_PUBLIC_AD_TEXT_PROVIDER=none
DISABLE_RPC_PROXY_API=false
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=03691a49de741a99212e711a54053fb0
# Internal transactions: the zksys EN exposes debug_traceBlockByNumber /
# debug_traceTransaction with callTracer, so enable the fetcher (powers the
# "Internal txns" tab and discovers CREATE2-deployed contracts).
INDEXER_DISABLE_INTERNAL_TRANSACTIONS_FETCHER=false

# ERC-4337 user operations: index Pali EntryPoint v0.9 (PackedUserOperation,
# v0.8-compatible wire format) through the user-ops-indexer microservice.
COMPOSE_PROFILES=user-ops
MICROSERVICE_ACCOUNT_ABSTRACTION_ENABLED=true
MICROSERVICE_ACCOUNT_ABSTRACTION_URL=http://user-ops-indexer:8050
USER_OPS_ENTRYPOINT_V08_ADDRESSES=0x433709009B8330FDa32311DF1C2AFA402eD8D009
NEXT_PUBLIC_HAS_USER_OPS=true
FOOTER_LINKS=[{"title":"Our Networks","links":[{"text":"Website","url":"https://syscoin.org"},{"text":"X (ex Twitter)","url":"https://x.com/syscoin"},{"text":"Discord","url":"https://discord.gg/syscoin"},{"text":"Contribute","url":"https://github.com/syscoin"}]},{"title":"Mainnets","links":[{"text":"Syscoin NEVM","url":"https://explorer.syscoin.org/"},{"text":"Syscoin UTXO","url":"https://explorer-blockbook.syscoin.org/"}]},{"title":"Testnets","links":[{"text":"Syscoin NEVM Testnet","url":"https://explorer.tanenbaum.io/"},{"text":"Syscoin UTXO Testnet","url":"https://explorer-blockbook-dev.syscoin.org/"},{"text":"zkTanenbaum","url":"https://explorer-zk.tanenbaum.io"},{"text":"Gateway Explorer","url":"https://explorer-gw.tanenbaum.io"}]}]
OTHER_LINKS=[]
