--- /dev/null
+++ b/basic_system/src/system_functions/slh_dsa_sha2_128_24_verify.rs
@@ -0,0 +1,251 @@
+use crate::cost_constants::{
+    SLH_DSA_SHA2_128_24_VERIFY_COST_ERGS, SLH_DSA_SHA2_128_24_VERIFY_NATIVE_COST,
+};
+use ruint::aliases::U256;
+use zk_ee::common_traits::TryExtend;
+use zk_ee::out_of_return_memory;
+use zk_ee::system::{
+    base_system_functions::{SlhDsaSha212824VerifyErrors, SystemFunction},
+    errors::subsystem::SubsystemError,
+    Computational, Resources,
+};
+
+const N: usize = 16;
+const SIGNATURE_LEN: usize = 3856;
+const INPUT_LEN: usize = 32 + 32 + 32 + SIGNATURE_LEN;
+const FORS_TREES: usize = 6;
+const FORS_HEIGHT: usize = 24;
+const WOTS_LEN: usize = 68;
+const MERKLE_HEIGHT: usize = 22;
+
+pub struct SlhDsaSha212824VerifyImpl;
+
+impl<R: Resources> SystemFunction<R, SlhDsaSha212824VerifyErrors> for SlhDsaSha212824VerifyImpl {
+    fn execute<D: TryExtend<u8> + ?Sized, A: core::alloc::Allocator + Clone>(
+        src: &[u8],
+        dst: &mut D,
+        resources: &mut R,
+        _: A,
+    ) -> Result<(), SubsystemError<SlhDsaSha212824VerifyErrors>> {
+        let native = <R as Resources>::Native::from_computational(
+            SLH_DSA_SHA2_128_24_VERIFY_NATIVE_COST,
+        );
+        resources.charge(&R::from_ergs_and_native(
+            SLH_DSA_SHA2_128_24_VERIFY_COST_ERGS,
+            native,
+        ))?;
+
+        let result = if slh_dsa_sha2_128_24_verify(src) {
+            ruint::aliases::U256::ONE
+        } else {
+            ruint::aliases::U256::ZERO
+        };
+        dst.try_extend(result.to_be_bytes::<32>())
+            .map_err(|_| out_of_return_memory!())?;
+        Ok(())
+    }
+}
+
+fn slh_dsa_sha2_128_24_verify(src: &[u8]) -> bool {
+    if src.len() != INPUT_LEN {
+        return false;
+    }
+
+    let seed = match canonical_n(&src[0..32]) {
+        Some(value) => value,
+        None => return false,
+    };
+    let root = match canonical_n(&src[32..64]) {
+        Some(value) => value,
+        None => return false,
+    };
+    let message: &[u8; 32] = src[64..96].try_into().expect("slice length checked");
+    let sig = &src[96..];
+
+    let digest_word = message_digest_word(&seed, &root, message, sig);
+    let leaf_idx =
+        (((digest_word[18] as u32) & 0x3f) << 16) | ((digest_word[19] as u32) << 8) | digest_word[20] as u32;
+
+    let fors_base = (U256::from(3u64) << 176) | (U256::from(leaf_idx) << 144);
+    let wots_base = U256::from(leaf_idx) << 144;
+    let mut fors_roots = [[0u8; N]; FORS_TREES];
+
+    for (t, fors_root) in fors_roots.iter_mut().enumerate() {
+        let md_t_offset = t * 3;
+        let md_t = ((digest_word[md_t_offset] as u32) << 16)
+            | ((digest_word[md_t_offset + 1] as u32) << 8)
+            | digest_word[md_t_offset + 2] as u32;
+        let tree_offset = N + t * (N + FORS_HEIGHT * N);
+        let sk = n_at(sig, tree_offset);
+        let mut node = hash_n(&seed, fors_base | (U256::from(((t as u32) << 24) | md_t) << 80), &[sk]);
+        let mut path_idx = md_t;
+
+        for j in 0..FORS_HEIGHT {
+            let sibling = n_at(sig, tree_offset + N + j * N);
+            let parent_idx = path_idx >> 1;
+            let global_y = ((t as u32) << (23 - j)) | parent_idx;
+            let address = fors_base | (U256::from((j + 1) as u64) << 112) | (U256::from(global_y) << 80);
+            node = if path_idx & 1 == 0 {
+                hash_n(&seed, address, &[node, sibling])
+            } else {
+                hash_n(&seed, address, &[sibling, node])
+            };
+            path_idx = parent_idx;
+        }
+        *fors_root = node;
+    }
+
+    let current_node = hash_n(&seed, (U256::from(4u64) << 176) | (U256::from(leaf_idx) << 144), &fors_roots);
+    let wots_ptr = N + FORS_TREES * (N + FORS_HEIGHT * N);
+    let mut csum = 0u32;
+    let mut wots_chains = [[0u8; N]; WOTS_LEN];
+
+    for (i, wots_chain) in wots_chains.iter_mut().take(64).enumerate() {
+        let digit = base4_digit(&current_node, i);
+        csum += 3 - digit as u32;
+        let mut value = n_at(sig, wots_ptr + i * N);
+        let chain_base = wots_base | (U256::from(i as u64) << 112);
+        for s in 0..(3 - digit) {
+            value = hash_n(&seed, chain_base | (U256::from((digit + s) as u64) << 80), &[value]);
+        }
+        *wots_chain = value;
+    }
+
+    for j in 0..4 {
+        let digit = ((csum >> (6 - 2 * j)) & 3) as u8;
+        let i = 64 + j;
+        let mut value = n_at(sig, wots_ptr + i * N);
+        let chain_base = wots_base | (U256::from(i as u64) << 112);
+        for s in 0..(3 - digit) {
+            value = hash_n(&seed, chain_base | (U256::from((digit + s) as u64) << 80), &[value]);
+        }
+        wots_chains[i] = value;
+    }
+
+    let wots_pk = hash_n(&seed, (U256::from(1u64) << 176) | (U256::from(leaf_idx) << 144), &wots_chains);
+    let auth_ptr = wots_ptr + WOTS_LEN * N;
+    let mut merkle_node = wots_pk;
+    let mut merkle_idx = leaf_idx;
+
+    for height in 0..MERKLE_HEIGHT {
+        let sibling = n_at(sig, auth_ptr + height * N);
+        let parent_idx = merkle_idx >> 1;
+        let address =
+            (U256::from(2u64) << 176) | (U256::from((height + 1) as u64) << 112) | (U256::from(parent_idx) << 80);
+        merkle_node = if merkle_idx & 1 == 0 {
+            hash_n(&seed, address, &[merkle_node, sibling])
+        } else {
+            hash_n(&seed, address, &[sibling, merkle_node])
+        };
+        merkle_idx = parent_idx;
+    }
+
+    merkle_node == root
+}
+
+fn canonical_n(word: &[u8]) -> Option<[u8; N]> {
+    if word.len() != 32 || word[N..].iter().any(|byte| *byte != 0) {
+        return None;
+    }
+    Some(word[..N].try_into().expect("slice length checked"))
+}
+
+fn n_at(src: &[u8], offset: usize) -> [u8; N] {
+    src[offset..offset + N].try_into().expect("SLH-DSA offsets are fixed")
+}
+
+fn message_digest_word(seed: &[u8; N], root: &[u8; N], message: &[u8; 32], sig: &[u8]) -> [u8; 32] {
+    let mut input = [0u8; 82];
+    input[0..N].copy_from_slice(&sig[0..N]);
+    input[16..32].copy_from_slice(seed);
+    input[32..48].copy_from_slice(root);
+    input[50..82].copy_from_slice(message);
+    let first = sha256(&input);
+
+    let mut second_input = [0u8; 68];
+    second_input[0..N].copy_from_slice(&sig[0..N]);
+    second_input[16..32].copy_from_slice(seed);
+    second_input[32..64].copy_from_slice(&first);
+    sha256(&second_input)
+}
+
+fn hash_n<const M: usize>(seed: &[u8; N], address: U256, parts: &[[u8; N]; M]) -> [u8; N] {
+    let mut input = [0u8; 1174];
+    input[0..N].copy_from_slice(seed);
+    let address_bytes = address.to_be_bytes::<32>();
+    input[64..86].copy_from_slice(&address_bytes[..22]);
+    let mut offset = 86;
+    for part in parts {
+        input[offset..offset + N].copy_from_slice(part);
+        offset += N;
+    }
+    let digest = sha256(&input[..offset]);
+    digest[..N].try_into().expect("slice length checked")
+}
+
+fn sha256(input: &[u8]) -> [u8; 32] {
+    use crypto::sha256::*;
+    let mut hasher = Sha256::new();
+    hasher.update(input);
+    hasher.finalize().into()
+}
+
+fn base4_digit(value: &[u8; N], index: usize) -> u8 {
+    (value[index / 4] >> (6 - 2 * (index % 4))) & 3
+}
